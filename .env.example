# ─────────────────────────────────────────────────────────────
# Luminary — environment variables template
# Copy this file to .env and fill in your real keys
# NEVER commit your .env file to GitHub
# ─────────────────────────────────────────────────────────────

# Get from: https://aistudio.google.com → Get API key
GOOGLE_API_KEY=

# Get from: https://console.cloud.google.com → Enable YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=

# Get from: https://console.cloud.google.com → Enable Custom Search API
GOOGLE_SEARCH_API_KEY=

# Get from: https://cse.google.com → Create search engine → Copy CX ID
GOOGLE_SEARCH_CX=

# Any random long string — used to sign session tokens
SESSION_SECRET=luminary_super_secret_change_this_in_production
